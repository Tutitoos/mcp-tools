HOST_HOME=/home/YOUR_USER
HOST_UID=1000
HOST_GID=1000

MCP_TOOLS_ROOT=/home/YOUR_USER/mcp-tools
MCP_TOOLS_DATA=/home/YOUR_USER/mcp-tools-data
# Bind for the web panel AND the published Docker ports (ollama 11434, qdrant 6333).
# This example uses loopback (safe). NOTE: the auto-generated .env (RunEnv) writes
# 0.0.0.0 — panel + services reachable from the whole LAN, without auth. Keep
# 127.0.0.1 unless you deliberately want LAN access (and firewall accordingly).
MCP_TOOLS_BIND=127.0.0.1

MEM0_USER_ID=YOUR_USER

# MongoDB MCP: use either a connection string or Atlas API credentials.
MDB_MCP_CONNECTION_STRING=
MDB_MCP_API_CLIENT_ID=
MDB_MCP_API_CLIENT_SECRET=

# Redis MCP.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=default
REDIS_PWD=
REDIS_SSL=false
