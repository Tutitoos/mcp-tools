{
  "$schema": "https://raw.githubusercontent.com/can1357/oh-my-pi/main/packages/coding-agent/src/config/mcp-schema.json",
  "mcpServers": {
    "codebase_memory_mcp": {
      "command": "/home/YOUR_USER/.local/bin/codebase-memory-mcp-docker",
      "args": ["--ui=false"],
      "env": {
        "HOME": "/home/YOUR_USER"
      }
    }
  }
}
