#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="${MCP_CUSTOM_ROOT:-$HOME/mcp-custom}"
ENV_FILE="$REPO_DIR/.env"
ENV_MEM0_FILE="$REPO_DIR/.env.mem0"
SERVICE_NAME="mem0"
CONTAINER_NAME="mcp-custom-mem0-mcp"

if [ ! -f "$ENV_FILE" ]; then
  "$REPO_DIR/scripts/init-env.sh" >&2
fi

if [ ! -f "$ENV_MEM0_FILE" ]; then
  echo "ERROR: missing $ENV_MEM0_FILE" >&2
  echo "Create it with MEM0_PROVIDER, MEM0_LLM_MODEL, MEM0_QDRANT_URL, MEM0_OLLAMA_URL, etc." >&2
  exit 1
fi

set -a
# shellcheck disable=SC1090
. "$ENV_FILE"
# shellcheck disable=SC1090
. "$ENV_MEM0_FILE"
set +a

mkdir -p \
  "$MCP_CUSTOM_DATA/mem0/history" \
  "$MCP_CUSTOM_DATA/mem0/uv-cache" \
  "$MCP_CUSTOM_DATA/mem0/config"

if [ ! -d "$MEM0_SRC_PATH" ]; then
  echo "ERROR: MEM0_SRC_PATH does not exist: $MEM0_SRC_PATH" >&2
  exit 1
fi

if ! docker container inspect "$CONTAINER_NAME" >/dev/null 2>&1; then
  docker compose \
    --project-directory "$REPO_DIR" \
    up -d "$SERVICE_NAME" >&2
elif [ "$(docker inspect -f '{{.State.Running}}' "$CONTAINER_NAME")" != "true" ]; then
  docker start "$CONTAINER_NAME" >&2
fi

exec docker exec -i \
  -e HOME=/home/mcp \
  -e UV_CACHE_DIR=/home/mcp/.cache/uv \
  -e PYTHONUNBUFFERED=1 \
  -w /opt/mem0-src \
  "$CONTAINER_NAME" \
  uvx --quiet --from /opt/mem0-src mem0-mcp-selfhosted \
  "$@"
