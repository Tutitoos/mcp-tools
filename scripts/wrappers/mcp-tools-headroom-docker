#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="${MCP_TOOLS_ROOT:-$HOME/mcp-tools}"
ENV_FILE="$REPO_DIR/.env"
SERVICE_NAME="mcp_tools_headroom"
CONTAINER_NAME="mcp-tools-headroom"

if [ ! -f "$ENV_FILE" ]; then
  echo "ERROR: $ENV_FILE no existe. Ejecuta 'mcp-tools install' primero." >&2
  exit 1
fi

set -a
# shellcheck disable=SC1090
. "$ENV_FILE"
set +a

mkdir -p \
  "$MCP_TOOLS_DATA/headroom/cache" \
  "$MCP_TOOLS_DATA/headroom/config" \
  "$MCP_TOOLS_DATA/headroom/share"

if ! docker container inspect "$CONTAINER_NAME" >/dev/null 2>&1; then
  docker compose \
    -f "$REPO_DIR/dockers/compose.yaml" \
    --env-file "$REPO_DIR/.env" \
    up -d "$SERVICE_NAME" >&2
elif [ "$(docker inspect -f '{{.State.Running}}' "$CONTAINER_NAME")" != "true" ]; then
  docker start "$CONTAINER_NAME" >&2
fi

exec docker exec -i \
  -e HOME=/home/mcp \
  -e PYTHONUNBUFFERED=1 \
  -w "$HOST_HOME" \
  "$CONTAINER_NAME" \
  headroom mcp serve \
  "$@"
