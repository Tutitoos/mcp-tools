#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="${MCP_TOOLS_ROOT:-$HOME/mcp-tools}"
ENV_FILE="$REPO_DIR/.env"
SERVICE_NAME="mcp_tools_codebase_memory"
CONTAINER_NAME="mcp-tools-codebase-memory"

if [ ! -f "$ENV_FILE" ]; then
  "$REPO_DIR/scripts/init-env.sh" >&2
fi

set -a
# shellcheck disable=SC1090
. "$ENV_FILE"
set +a

mkdir -p \
  "$MCP_TOOLS_DATA/codebase-memory/cache" \
  "$MCP_TOOLS_DATA/codebase-memory/config"

if ! docker container inspect "$CONTAINER_NAME" >/dev/null 2>&1; then
  docker compose \
    -f "$REPO_DIR/dockers/compose.yaml" \
    --env-file "$REPO_DIR/.env" \
    up -d "$SERVICE_NAME" >&2
elif [ "$(docker inspect -f '{{.State.Running}}' "$CONTAINER_NAME")" != "true" ]; then
  docker start "$CONTAINER_NAME" >&2
fi

exec docker exec -i \
  -e HOME=/home/mcp \
  -e RUST_LOG=warn \
  -w "$HOST_HOME" \
  "$CONTAINER_NAME" \
  codebase-memory-mcp \
  "$@"
