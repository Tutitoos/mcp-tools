#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="${MCP_CUSTOM_ROOT:-$HOME/mcp-custom}"
ENV_FILE="$REPO_DIR/.env"
SERVICE_NAME="headroom"
CONTAINER_NAME="mcp-custom-headroom-mcp"

if [ ! -f "$ENV_FILE" ]; then
  "$REPO_DIR/scripts/init-env.sh" >&2
fi

set -a
# shellcheck disable=SC1090
. "$ENV_FILE"
set +a

mkdir -p \
  "$MCP_CUSTOM_DATA/headroom/cache" \
  "$MCP_CUSTOM_DATA/headroom/config" \
  "$MCP_CUSTOM_DATA/headroom/share"

if ! docker container inspect "$CONTAINER_NAME" >/dev/null 2>&1; then
  docker compose \
    --project-directory "$REPO_DIR" \
    up -d "$SERVICE_NAME" >&2
elif [ "$(docker inspect -f '{{.State.Running}}' "$CONTAINER_NAME")" != "true" ]; then
  docker start "$CONTAINER_NAME" >&2
fi

exec docker exec -i \
  -e HOME=/home/mcp \
  -e PYTHONUNBUFFERED=1 \
  -w "$HOST_HOME" \
  "$CONTAINER_NAME" \
  headroom mcp serve \
  "$@"
